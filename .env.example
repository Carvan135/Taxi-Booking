# Supabase (public + server)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe (test mode for development)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (local dev or production site URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_GEOAPIFY_API_KEY=2f40...

# Optional: verbose quote calculation logs in browser console (on by default in dev)
# NEXT_PUBLIC_DEBUG_QUOTE=true
# Server terminal (npm run dev): DEBUG_QUOTE=1 or automatic in development

# Optional: pre-filled "Contact operator" mailto for customers (e.g. support@yourdomain.com)
# NEXT_PUBLIC_SUPPORT_EMAIL=
