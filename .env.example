# Supabase (public + server)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe (test mode for development)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional runtime fallback if NEXT_PUBLIC_* is only set at deploy time (Cloudflare):
# STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (production: https://airporthub.co.uk)
NEXT_PUBLIC_APP_URL=https://airporthub.co.uk

# Geoapify (server-side; required on Cloudflare Workers for /api/geoapify/*)
GEOAPIFY_API_KEY=2f40...
# Legacy fallback (local only if you still use this name):
# NEXT_PUBLIC_GEOAPIFY_API_KEY=2f40...

# Optional: verbose quote calculation logs in browser console (on by default in dev)
# NEXT_PUBLIC_DEBUG_QUOTE=true
# Server terminal (npm run dev): DEBUG_QUOTE=1 or automatic in development

# Optional: override booking support mailto (defaults to bookings@airporthub.co.uk)
# NEXT_PUBLIC_SUPPORT_EMAIL=bookings@airporthub.co.uk

# Transactional email (Resend) — booking confirmations, trip updates, receipts
# https://resend.com — verify airporthub.co.uk (or your domain), then create an API key
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@airporthub.co.uk
RESEND_FROM_NAME=AirportHub
# Legacy single-line override (optional; RESEND_FROM_* takes precedence when unset)
# EMAIL_FROM=AirportHub <noreply@airporthub.co.uk>
